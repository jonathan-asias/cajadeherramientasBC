<?xml version="1.0" encoding="utf-8"?>
<!-- IIS: caché por defecto para contenido estático (mejora perf/cache-headers en auditorías). -->
<configuration>
  <system.webServer>
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="7.00:00:00" />
    </staticContent>
  </system.webServer>
</configuration>
